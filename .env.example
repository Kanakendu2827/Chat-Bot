# Frontend API Keys (Gemini)
# Rename this file to .env and replace with your actual API key.
# Use a Google Cloud API key for Gemini, or an OpenRouter key starting with sk-or- for OpenRouter.
# If you prefer, you can also use OPENROUTER_API_KEY for OpenRouter.
# Do not paste an OAuth token, ID token, or service account JSON value here.
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# VITE_OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Backend Server Configuration
PORT=3001
NODE_ENV=development

# Backend API Keys (used by server.js)
# Use one of the following:
GEMINI_API_KEY=your_gemini_api_key_here
# OPENROUTER_API_KEY=sk-or-your-openrouter-key

